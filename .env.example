# Required for event unlock + API. Min 6 characters. Never commit the real value to git.
# Production: set the same variable on your host (e.g. Render → Environment).
# Website: organizers enter it once on Events → “Unlock”; then an HttpOnly cookie is used (not stored in HTML/JS).
# Discord bots: send "secret" in JSON for POST /api/custom-events (create) and for deletes (see DISCORD_EVENTS.md).
CLAN_EVENTS_SECRET=replace-with-your-secret

# Optional: Discord Incoming Webhook — when someone adds an event on the site, the server POSTs an embed here.
# Create: Server → channel → Edit channel → Integrations → Webhooks → New Webhook → Copy Webhook URL.
# This is a secret (like a password). Use .env locally and Render → Environment in production — do not commit the real URL.
DISCORD_EVENTS_WEBHOOK_URL=

# Optional: public site URL (no trailing slash) so the Discord embed can link to https://yoursite.com/#/events
PUBLIC_SITE_URL=https://your-site.example.com

# Optional: display name / HTTPS image URL for webhook avatar (otherwise defaults to “Terpinheimer” / no avatar).
DISCORD_WEBHOOK_USERNAME=Terpinheimer.com
# DISCORD_WEBHOOK_AVATAR_URL=https://example.com/your-bot-avatar.png

# Optional: reduce Discord 429s — min ms between webhook POSTs (default 2500), max 429 retries (default 6).
# DISCORD_WEBHOOK_MIN_INTERVAL_MS=3000
# DISCORD_WEBHOOK_MAX_RETRIES=8

# Optional: where to store clan events JSON (survives restarts if this path is on a persistent disk).
# Render native Node: mount a disk at /opt/render/project/src/_data or set e.g. CUSTOM_EVENTS_DIR=/var/data
# CUSTOM_EVENTS_DIR=/var/data
# Or full file path: CUSTOM_EVENTS_PATH=/var/data/custom-events.json

# Optional: RuneLite / live map shared secret. On Render, set LIVE_MAP_SECRET to match the plugin
# (e.g. TerpinheimerCC). If unset, POST is open (dev only — set this in production).
# LIVE_MAP_SECRET=TerpinheimerCC
#
# Auth headers the server accepts (same string as LIVE_MAP_SECRET):
#   Authorization: TerpinheimerCC          (exact value, no "Bearer " — RuneLite-friendly)
#   Authorization: Bearer TerpinheimerCC
#   X-Live-Map-Key: TerpinheimerCC
# Or JSON body fields: sharedKey | key | secret
#
# RuneLite plugin configuration (example host: https://terpinheimercc.onrender.com):
#   API base URL:  https://terpinheimercc.onrender.com
#   POST path:      /post   → full URL https://terpinheimercc.onrender.com/post
#   Shared key:     same as LIVE_MAP_SECRET (e.g. TerpinheimerCC), in Authorization unless the
#                   plugin sends it as Bearer or X-Live-Map-Key.
# The site map reads positions from GET /api/live-map-players (no secret required).
#
# Same JSON also works on POST /api/live-map-players (merge defaults on for { name, waypoint } bodies).
# Optional: drop players after N ms without an update (default 120000).
# LIVE_MAP_PLAYER_TTL_MS=120000

# Optional: RuneLite plugin read access for GET /api/runelite/clan-events (clan calendar on Events page).
# If unset, the endpoint is public (same data as GET /api/custom-events, stable JSON envelope for plugins).
# If set, require the same value via ?key=…, X-Runelite-Key, or Authorization (raw or Bearer).
# Example: https://yoursite.onrender.com/api/runelite/clan-events
# Same handler: /api/runelite/clan-calendar-summary (for “summary API” plugin fields).
# Query: upcoming=1, since=ISO, format=array (bare JSON list), format=events (same).
# RUNELITE_CLAN_EVENTS_SECRET=

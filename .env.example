# Required for event unlock + API. Min 6 characters. Never commit the real value to git.
# Production: set the same variable on your host (e.g. Render → Environment).
# Website: organizers enter it once on Events → “Unlock”; then an HttpOnly cookie is used (not stored in HTML/JS).
# Discord bots: send "secret" in JSON for POST /api/custom-events (create) and for deletes (see DISCORD_EVENTS.md).
CLAN_EVENTS_SECRET=replace-with-your-secret

# Optional: Discord Incoming Webhook — when someone adds an event on the site, the server POSTs an embed here.
# Create: Server → channel → Edit channel → Integrations → Webhooks → New Webhook → Copy Webhook URL.
# This is not your bot token; it’s a URL that only posts to one channel. See DISCORD_EVENTS.md for bot tips.
DISCORD_EVENTS_WEBHOOK_URL=

# Optional: public site URL (no trailing slash) so the Discord embed can link to https://yoursite.com/#/events
PUBLIC_SITE_URL=https://your-site.example.com

# Optional: display name / avatar for webhook messages (otherwise defaults to “Terpinheimer”).
DISCORD_WEBHOOK_USERNAME=
DISCORD_WEBHOOK_AVATAR_URL=

# Optional: where to store clan events JSON (survives restarts if this path is on a persistent disk).
# Render native Node: mount a disk at /opt/render/project/src/_data or set e.g. CUSTOM_EVENTS_DIR=/var/data
# CUSTOM_EVENTS_DIR=/var/data
# Or full file path: CUSTOM_EVENTS_PATH=/var/data/custom-events.json
